<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Nouvelle inscription — La Récrée Tech</title>
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background-color: #FCFAF5; color: #1F3025;">

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background: #FCFAF5; padding: 40px 20px;">
        <tr>
            <td align="center">
                <table role="presentation" width="560" cellpadding="0" cellspacing="0" border="0" style="background: #ffffff; border: 1px solid #efe9df; border-radius: 16px; overflow: hidden;">

                    <tr>
                        <td style="background: #1F3025; padding: 28px 32px; color: #FCFAF5;">
                            <div style="font-family: 'Georgia', serif; font-style: italic; font-size: 22px; color: #C8395E;">la <em>récrée</em> tech.</div>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding: 32px;">
                            <div style="font-family: 'DM Mono', 'Courier New', monospace; font-size: 11px; letter-spacing: 0.12em; color: #C8395E; text-transform: uppercase; margin-bottom: 12px;">— {{ alreadyEnrolled ? 'Nouveau paiement' : 'Nouvelle inscription' }}</div>
                            <h1 style="font-family: 'Georgia', serif; font-size: 26px; font-weight: 500; line-height: 1.2; margin: 0 0 20px; color: #1F3025;">
                                {{ alreadyEnrolled ? 'Un client a repayé 💸' : 'Quelqu\'un vient de s\'inscrire 🎉' }}
                            </h1>

                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="font-size: 15px; line-height: 1.6; color: #1F3025;">
                                <tr>
                                    <td style="padding: 10px 0; border-bottom: 1px solid #efe9df; color: #5a6862; width: 140px;">Formation</td>
                                    <td style="padding: 10px 0; border-bottom: 1px solid #efe9df;"><strong>{{ formation.title }}</strong></td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 0; border-bottom: 1px solid #efe9df; color: #5a6862;">Client</td>
                                    <td style="padding: 10px 0; border-bottom: 1px solid #efe9df;">{{ user.firstName }} &lt;{{ user.email }}&gt;</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 0; border-bottom: 1px solid #efe9df; color: #5a6862;">Montant</td>
                                    <td style="padding: 10px 0; border-bottom: 1px solid #efe9df;"><strong style="color: #C8395E;">{{ (payment.amountCents / 100)|number_format(0, ',', ' ') }} {{ payment.currency }}</strong></td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 0; border-bottom: 1px solid #efe9df; color: #5a6862;">Date</td>
                                    <td style="padding: 10px 0; border-bottom: 1px solid #efe9df;">{{ payment.createdAt|date('d/m/Y · H:i') }}</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px 0; color: #5a6862;">Réf. Stripe</td>
                                    <td style="padding: 10px 0; font-family: 'Courier New', monospace; font-size: 12px; word-break: break-all;">{{ payment.stripePaymentIntentId ?? payment.stripeSessionId }}</td>
                                </tr>
                            </table>

                            {% if alreadyEnrolled %}
                            <p style="font-size: 13px; color: #5a6862; line-height: 1.6; margin: 24px 0 0;">
                                Note : ce client était déjà inscrit à cette formation (rachat ou mensualité).
                            </p>
                            {% endif %}
                        </td>
                    </tr>

                    <tr>
                        <td style="background: #FCFAF5; padding: 20px 32px; border-top: 1px solid #efe9df; font-size: 12px; color: #5a6862;">
                            Notification automatique · La Récrée Tech
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>

</body>
</html>
