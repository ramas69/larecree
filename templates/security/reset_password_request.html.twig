{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — La Récrée Tech{% endblock %}

{% block body %}
<div class="auth-page">

    <header class="auth-header">
        <a href="{{ path('app_login') }}" class="auth-brand" aria-label="La Récrée Tech">
            <span>la <em>récrée</em> tech.</span>
        </a>
        <a href="{{ path('app_login') }}" class="auth-header-link">← Retour</a>
    </header>

    <main class="auth-main">
        <div class="auth-card">
            <span class="auth-eyebrow">— Mot de passe oublié</span>
            <h1 class="auth-title">Pas grave, ça <em>arrive</em>.</h1>

            {% if sent %}
                <p class="auth-sub">
                    Si un compte existe avec cette adresse, un email avec un lien de réinitialisation vient d'être envoyé.
                    Vérifie ta boîte (et les spams). Le lien est valable 60 minutes.
                </p>
                <a href="{{ path('app_login') }}" class="auth-btn">Retour à la connexion</a>
            {% else %}
                <p class="auth-sub">Indique l'email de ton compte. On t'envoie un lien magique pour redéfinir ton mot de passe.</p>

                <form method="post" novalidate data-turbo="false">
                    <div class="auth-field">
                        <label for="inputEmail">Email du compte</label>
                        <input type="email" id="inputEmail" name="email" required autofocus autocomplete="email" placeholder="toi@exemple.com">
                    </div>

                    <input type="hidden" name="_token" value="{{ csrf_token('reset_request') }}">

                    <button type="submit" class="auth-btn">Envoyer le lien</button>
                </form>
            {% endif %}
        </div>
    </main>

</div>
{% endblock %}
