{% extends 'base.html.twig' %}

{% block title %}Lien invalide — La Récrée Tech{% endblock %}

{% block body %}
<div class="auth-page">

    <header class="auth-header">
        <a href="{{ path('app_login') }}" class="auth-brand" aria-label="La Récrée Tech">
            <span>la <em>récrée</em> tech.</span>
        </a>
        <a href="{{ path('app_login') }}" class="auth-header-link">← Retour</a>
    </header>

    <main class="auth-main">
        <div class="auth-card">
            <span class="auth-eyebrow">— Oups</span>
            <h1 class="auth-title">Ce lien n'est <em>plus valide</em>.</h1>
            <p class="auth-sub">Il a peut-être expiré (60 min max) ou déjà été utilisé. Tu peux en demander un nouveau.</p>

            <a href="{{ path('app_reset_password_request') }}" class="auth-btn">Demander un nouveau lien</a>
        </div>
    </main>

</div>
{% endblock %}
