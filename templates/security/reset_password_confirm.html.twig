{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe — La Récrée Tech{% endblock %}

{% block body %}
<div class="auth-page">

    <header class="auth-header">
        <a href="{{ path('app_login') }}" class="auth-brand" aria-label="La Récrée Tech">
            <span>la <em>récrée</em> tech.</span>
        </a>
        <a href="{{ path('app_login') }}" class="auth-header-link">← Retour</a>
    </header>

    <main class="auth-main">
        <div class="auth-card">
            <span class="auth-eyebrow">— Réinitialisation</span>
            <h1 class="auth-title">Choisis ton <em>nouveau</em> mot de passe.</h1>
            <p class="auth-sub">Pour <strong>{{ user.email }}</strong>. Mini 8 caractères.</p>

            {% for error in errors %}
                <div class="auth-alert">{{ error }}</div>
            {% endfor %}

            <form method="post" novalidate>
                <div class="auth-field">
                    <label for="inputPassword">Nouveau mot de passe</label>
                    <input type="password" id="inputPassword" name="password" required autocomplete="new-password" minlength="8" autofocus>
                </div>

                <div class="auth-field">
                    <label for="inputPasswordConfirm">Confirme</label>
                    <input type="password" id="inputPasswordConfirm" name="password_confirm" required autocomplete="new-password" minlength="8">
                </div>

                <input type="hidden" name="_token" value="{{ csrf_token('reset_confirm_' ~ token) }}">

                <button type="submit" class="auth-btn">Mettre à jour</button>
            </form>
        </div>
    </main>

</div>
{% endblock %}
