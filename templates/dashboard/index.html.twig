{% extends 'base.html.twig' %}

{% block title %}Dashboard — La Récrée Tech{% endblock %}

{% block body %}
<div class="app-shell">

    <header class="app-header">
        <div class="app-header-inner">
            <a href="{{ path('app_dashboard') }}" class="app-brand" aria-label="La Récrée Tech">
                <svg class="app-brand-svg" viewBox="0 0 280 280" aria-hidden="true">
                    <g transform="translate(20, 20)">
                        <path d="M 120 0 A 100 100 0 0 1 207 50 L 190 60 A 80 80 0 0 0 120 20 Z" fill="#C8395E"/>
                        <path d="M 207 50 A 100 100 0 0 1 207 150 L 190 140 A 80 80 0 0 0 190 60 Z" fill="#C8395E"/>
                        <path d="M 207 150 A 100 100 0 0 1 120 200 L 120 180 A 80 80 0 0 0 190 140 Z" fill="none" stroke="#C8395E" stroke-width="3" opacity="0.4"/>
                        <path d="M 120 200 A 100 100 0 0 1 33 150 L 50 140 A 80 80 0 0 0 120 180 Z" fill="none" stroke="#C8395E" stroke-width="3" opacity="0.4"/>
                        <path d="M 33 150 A 100 100 0 0 1 33 50 L 50 60 A 80 80 0 0 0 50 140 Z" fill="none" stroke="#C8395E" stroke-width="3" opacity="0.4"/>
                        <path d="M 33 50 A 100 100 0 0 1 120 0 L 120 20 A 80 80 0 0 0 50 60 Z" fill="none" stroke="#C8395E" stroke-width="3" opacity="0.4"/>
                        <text x="120" y="118" font-family="Fraunces, Georgia, serif" font-size="36" font-weight="500" font-style="italic" fill="#C8395E" text-anchor="middle" letter-spacing="-1.5">récrée</text>
                    </g>
                </svg>
                <span>la <em>récrée</em> tech<span class="dot">.</span></span>
            </a>

            <nav class="app-nav" aria-label="Navigation">
                <a href="{{ path('app_dashboard') }}">Mes formations</a>
                <a href="#">Catalogue</a>
                <a href="#">Communauté</a>
                {% if app.user.isAdmin %}<a href="{{ path('admin') }}" style="color: var(--rose);">Admin</a>{% endif %}
            </nav>

            <div style="display: flex; align-items: center;">
                <div class="app-user-menu">
                    <span class="app-avatar" aria-hidden="true">{{ app.user.firstName|first }}</span>
                    <span class="app-user-name">{{ app.user.firstName }}</span>
                </div>
                <a href="{{ path('app_logout') }}" class="app-logout">Déconnexion</a>
            </div>
        </div>
    </header>

    <main class="app-main">

        <section class="dash-hero">
            <span class="dash-hero-caveat">salut {{ app.user.firstName }}</span>
            <h1 class="dash-hero-title">Bon <em>retour</em>.</h1>
            <p class="dash-hero-sub">Reprends ton parcours là où tu l'as laissé, ou explore une nouvelle formation.</p>
        </section>

        <section class="dash-stats">
            <div class="dash-stat">
                <span class="dash-stat-label">— Formations</span>
                <div class="dash-stat-value">{{ snapshot.enrollmentsInProgressCount }}</div>
                <span class="dash-stat-hint">en cours</span>
            </div>
            <div class="dash-stat">
                <span class="dash-stat-label">— Heures vidéo</span>
                <div class="dash-stat-value">{{ snapshot.totalWatchedHours }}</div>
                <span class="dash-stat-hint">accumulées</span>
            </div>
            <div class="dash-stat">
                <span class="dash-stat-label">— Progression</span>
                <div class="dash-stat-value">{{ snapshot.averageProgressPercent }}%</div>
                <span class="dash-stat-hint">moyenne</span>
            </div>
            <div class="dash-stat">
                <span class="dash-stat-label">— Certificats</span>
                <div class="dash-stat-value">{{ snapshot.certificatesCount }}</div>
                <span class="dash-stat-hint">obtenus</span>
            </div>
        </section>

        {% if snapshot.currentProgress %}
        {% set cur = snapshot.currentProgress %}
        {% set lesson = cur.lesson %}
        {% set module = lesson.module %}
        {% set formation = module.formation %}
        {% set total = lesson.durationSeconds %}
        {% set watched = cur.watchedSeconds %}
        {% set remaining = (total - watched) > 0 ? (total - watched) : 0 %}
        <section class="dash-section">
            <div class="dash-section-head">
                <h2 class="dash-section-title">Reprendre <em>où tu en étais</em></h2>
                <a href="#" class="dash-section-action">Voir tout →</a>
            </div>

            <div class="dash-continue">
                <div class="dash-continue-thumb" aria-hidden="true">
                    <div class="dash-continue-thumb-play">▶</div>
                    <span class="dash-continue-thumb-time">{{ lesson.durationFormatted }}</span>
                </div>
                <div class="dash-continue-body">
                    <span class="dash-continue-eyebrow">★ {{ formation.title }} · M{{ '%02d'|format(module.displayOrder) }} · Leçon {{ lesson.displayOrder }}</span>
                    <h3>{{ lesson.title }}</h3>
                    <p class="dash-continue-meta">Tu en es à {{ (watched // 60) }} min {{ (watched % 60) }} s sur {{ lesson.durationFormatted }} · {{ (remaining // 60) }} min restantes</p>

                    <div class="dash-progress-bar">
                        <div class="dash-progress-bar-fill" style="width: {{ cur.percentWatched }}%;"></div>
                    </div>
                    <div class="dash-progress-meta">
                        <span><strong>{{ cur.percentWatched }} %</strong> de la leçon</span>
                        <span>Vue {{ cur.lastWatchedAt|date('d/m/Y') }}</span>
                    </div>

                    <a href="#" class="dash-continue-cta">▶ Reprendre la leçon</a>
                </div>
            </div>
        </section>
        {% endif %}

        {% if snapshot.enrollmentSnapshots|length > 0 %}
        <section class="dash-section">
            <div class="dash-section-head">
                <h2 class="dash-section-title">
                    {% if snapshot.enrollmentSnapshots|length > 1 %}Tes <em>parcours</em>{% else %}Ton <em>parcours</em>{% endif %}
                </h2>
                <a href="#" class="dash-section-action">Catalogue →</a>
            </div>

            {% for es in snapshot.enrollmentSnapshots %}
            {% set pm = es.progressMap %}
            {% set formation = es.enrollment.formation %}
            <div class="dash-progress-map" aria-label="Carte de progression {{ formation.title }}" {% if not loop.first %}style="margin-top: 1.5rem;"{% endif %}>
                <div class="dash-progress-map-title">
                    <span>— <strong>{{ formation.title }}</strong> {% if es.enrollment.isVipGranted %}<em style="color: var(--rose);">· VIP</em>{% endif %}</span>
                    <span><em>Progression : {{ pm.overallPercent }} %</em> · {{ pm.doneModulesCount }} modules validés sur {{ pm.totalModulesCount }}</span>
                </div>

                <div class="map-track">
                    {% for item in pm.items %}
                        <div class="map-node">
                            {% if item.state == 'done' %}
                                <span class="map-marker is-done" title="Module {{ item.label }} validé">✓</span>
                            {% elseif item.state == 'finale-done' %}
                                <span class="map-marker is-finale" title="Module {{ item.label }} — Finale validée">★</span>
                            {% elseif item.state == 'current' %}
                                <span class="map-marker is-current" title="Module {{ item.label }} en cours">{{ '%02d'|format(item.index) }}</span>
                            {% elseif item.state == 'finale' %}
                                <span class="map-marker is-finale" title="Module {{ item.label }} — Finale">★</span>
                            {% else %}
                                <span class="map-marker">{{ '%02d'|format(item.index) }}</span>
                            {% endif %}
                            <span class="map-label">{{ item.label }}</span>
                            {% if item.state == 'current' %}<span class="map-pct">{{ item.percent }}%</span>{% endif %}
                        </div>
                        {% if not loop.last %}
                            <div class="map-connector {{ item.state in ['done', 'finale-done'] ? 'is-done' : '' }}"></div>
                        {% endif %}
                    {% endfor %}
                </div>

                <div class="dash-progress-map-foot">
                    <span>Dernier module validé : <strong>{{ pm.lastCompletedTitle ?? '—' }}</strong></span>
                    <a href="#">→ Voir détail formation</a>
                </div>
            </div>
            {% endfor %}
        </section>
        {% endif %}

        <section class="dash-section">
            <div class="dash-section-head">
                <h2 class="dash-section-title">Activité <em>récente</em></h2>
            </div>

            <div class="dash-activity">
                <div class="dash-activity-item">
                    <span class="dash-activity-dot" aria-hidden="true"></span>
                    <div class="dash-activity-body">
                        <strong>Compte créé</strong>
                        <span>{{ app.user.createdAt|date('d/m/Y · H:i') }}</span>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <footer class="app-footer">
        © 2026 La Récrée Tech · app.larecreetech.com
    </footer>

</div>
{% endblock %}
