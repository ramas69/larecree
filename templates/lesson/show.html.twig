{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }} — {{ formation.title }}{% endblock %}

{% block body %}
<div class="app-shell">

    {% include '_partials/_app_header.html.twig' with { active_nav: 'catalogue' } %}

    <main class="app-main lp-layout">

        {# Tableau-noir hero banner #}
        <section class="lp-hero">
            <div class="lp-hero-grid" aria-hidden="true"></div>

            <nav class="lp-hero-crumbs" aria-label="Fil d'Ariane">
                <a href="{{ path('app_catalogue') }}">Catalogue</a>
                <span aria-hidden="true">›</span>
                <a href="{{ path('app_formation_show', { slug: formation.slug }) }}">{{ formation.title }}</a>
                <span aria-hidden="true">›</span>
                <span>M{{ '%02d'|format(module.displayOrder) }} · {{ module.title }}</span>
            </nav>

            <div class="lp-hero-body">
                <span class="lp-hero-eyebrow">★ Leçon {{ lesson.displayOrder }} sur {{ moduleStats.totalCount }} · {{ lesson.durationFormatted }}</span>
                <h1 class="lp-hero-title">{{ lesson.title }}</h1>

                <div class="lp-hero-module-bar">
                    <div class="lp-hero-module-info">
                        <span class="lp-hero-module-num">M{{ '%02d'|format(module.displayOrder) }}</span>
                        <span class="lp-hero-module-name">{{ module.title }}</span>
                    </div>
                    <div class="lp-hero-module-progress">
                        <progress max="100" value="{{ moduleStats.percent }}" aria-label="Progression module {{ module.title }}">{{ moduleStats.percent }} %</progress>
                        <span>{{ moduleStats.doneCount }} / {{ moduleStats.totalCount }} leçons · {{ moduleStats.percent }} %</span>
                    </div>
                </div>
            </div>
        </section>

        {% for message in app.flashes('success') %}
            <div class="lp-flash">
                <span class="lp-flash-icon" aria-hidden="true">✓</span>
                {{ message }}
            </div>
        {% endfor %}

        <div class="lp-grid">

            <article class="lp-main">

                <div class="lp-player">
                    <div class="lp-player-corners" aria-hidden="true"></div>
                    <div class="lp-player-frame">
                        <iframe
                            src="https://player.vimeo.com/video/{{ lesson.vimeoVideoId }}?title=0&byline=0&portrait=0"
                            title="{{ lesson.title }}"
                            allow="autoplay; fullscreen; picture-in-picture"
                            allowfullscreen
                            loading="lazy"></iframe>
                    </div>
                </div>

                {% set isDone = progress and progress.isCompleted %}

                <div class="lp-meta">
                    <div class="lp-meta-status">
                        {% if isDone %}
                            <span class="lp-pill is-done">✓ Terminée</span>
                            <span class="lp-meta-date">le {{ progress.completedAt|date('d/m/Y') }}</span>
                        {% elseif progress and progress.percentWatched > 0 %}
                            <span class="lp-pill is-progress">▶ En cours · {{ progress.percentWatched }} %</span>
                            <span class="lp-meta-date">Dernière vue {{ progress.lastWatchedAt|date('d/m/Y') }}</span>
                        {% else %}
                            <span class="lp-pill">○ À voir</span>
                        {% endif %}
                    </div>

                    {% if not isDone %}
                        <form method="post" action="{{ path('app_lesson_complete', { slug: formation.slug, moduleSlug: module.slug, lessonSlug: lesson.slug }) }}" class="lp-complete-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('lesson_complete_' ~ lesson.slug) }}">
                            <button type="submit" class="lp-complete-cta">
                                <span aria-hidden="true">✓</span> Marquer comme terminée
                            </button>
                        </form>
                    {% endif %}
                </div>

                {% if lesson.description %}
                    <section class="lp-description">
                        <span class="lp-description-eyebrow">— À retenir</span>
                        <h2 class="lp-description-title">Au programme de cette leçon</h2>
                        <p>{{ lesson.description }}</p>
                    </section>
                {% endif %}

                {% if lesson.resources|length > 0 %}
                    <section class="lp-resources">
                        <span class="lp-resources-eyebrow">— Ressources</span>
                        <h2 class="lp-resources-title">À télécharger · liens utiles</h2>
                        <ul class="lp-resources-list">
                            {% for r in lesson.resources %}
                                {% set isFile = r.type.value == 'file' %}
                                {% set href = isFile ? r.filePath : r.url %}
                                <li class="lp-resource {{ isFile ? 'is-file' : 'is-link' }}">
                                    <span class="lp-resource-icon" aria-hidden="true">{{ isFile ? '📄' : '🔗' }}</span>
                                    <div class="lp-resource-body">
                                        <span class="lp-resource-kind">{{ isFile ? 'PDF · à télécharger' : 'Lien externe' }}</span>
                                        <strong>{{ r.title }}</strong>
                                    </div>
                                    {% if href %}
                                        <a class="lp-resource-cta" href="{{ href }}" {{ isFile ? '' : 'target="_blank" rel="noopener"' }}>
                                            {{ isFile ? 'Télécharger →' : 'Ouvrir →' }}
                                        </a>
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    </section>
                {% endif %}

                <nav class="lp-nav" aria-label="Navigation leçons">
                    {% if prevLesson %}
                        <a href="{{ path('app_lesson_show', { slug: formation.slug, moduleSlug: prevLesson.module.slug, lessonSlug: prevLesson.slug }) }}" class="lp-nav-btn lp-nav-prev">
                            <span class="lp-nav-eyebrow">← Précédente</span>
                            <span class="lp-nav-title">{{ prevLesson.title }}</span>
                        </a>
                    {% else %}
                        <span class="lp-nav-btn is-disabled">
                            <span class="lp-nav-eyebrow">← Précédente</span>
                            <span class="lp-nav-title">Tu es au début</span>
                        </span>
                    {% endif %}

                    {% if nextLesson %}
                        <a href="{{ path('app_lesson_show', { slug: formation.slug, moduleSlug: nextLesson.module.slug, lessonSlug: nextLesson.slug }) }}" class="lp-nav-btn lp-nav-next">
                            <span class="lp-nav-eyebrow">Suivante →</span>
                            <span class="lp-nav-title">{{ nextLesson.title }}</span>
                        </a>
                    {% else %}
                        <span class="lp-nav-btn is-disabled">
                            <span class="lp-nav-eyebrow">Suivante →</span>
                            <span class="lp-nav-title">Fin de la formation 🎉</span>
                        </span>
                    {% endif %}
                </nav>
            </article>

            <aside class="lp-sidebar" aria-label="Leçons du module">
                <header class="lp-sidebar-head">
                    <span class="lp-sidebar-eyebrow">— Module {{ '%02d'|format(module.displayOrder) }}</span>
                    <h3 class="lp-sidebar-title">{{ module.title }}</h3>
                    <p class="lp-sidebar-meta">{{ moduleStats.totalCount }} leçons</p>
                </header>

                <ol class="lp-sidebar-list">
                    {% for l in allLessonsInModule %}
                        {% set isCurrent = l == lesson %}
                        {% set lp = progressByLessonId[l.id] ?? null %}
                        {% set lessonDone = lp and lp.isCompleted %}
                        {% set lessonStarted = lp and lp.percentWatched > 0 and not lessonDone %}
                        <li class="lp-side-item {{ isCurrent ? 'is-current' : '' }} {{ lessonDone ? 'is-done' : '' }} {{ lessonStarted ? 'is-started' : '' }}">
                            <a href="{{ path('app_lesson_show', { slug: formation.slug, moduleSlug: module.slug, lessonSlug: l.slug }) }}">
                                <span class="lp-side-mark" aria-hidden="true">
                                    {% if lessonDone %}✓{% elseif isCurrent %}▶{% else %}{{ loop.index }}{% endif %}
                                </span>
                                <span class="lp-side-text">
                                    <strong>{{ l.title }}</strong>
                                    <em>
                                        {{ l.durationFormatted }}
                                        {% if lessonStarted %} · {{ lp.percentWatched }} %{% endif %}
                                    </em>
                                </span>
                            </a>
                        </li>
                    {% endfor %}
                </ol>

                <a href="{{ path('app_formation_show', { slug: formation.slug }) }}" class="lp-sidebar-back">↩ Voir la formation complète</a>
            </aside>

        </div>

    </main>

    <footer class="app-footer">
        © 2026 La Récrée Tech · app.larecreetech.com
    </footer>

</div>
{% endblock %}
