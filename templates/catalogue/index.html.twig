{% extends 'base.html.twig' %}

{% block title %}Catalogue — La Récrée Tech{% endblock %}

{% block body %}
<div class="app-shell">

    {% include '_partials/_app_header.html.twig' with { active_nav: 'catalogue' } %}

    <main class="app-main">

        <section class="cat-hero">
            <div class="cat-hero-grid" aria-hidden="true"></div>
            <div class="cat-hero-inner">
                <span class="cat-hero-caveat">notre catalogue</span>
                <h1 class="cat-hero-title">Choisis ta <em>prochaine</em> formation.</h1>
                <p class="cat-hero-sub">Toutes nos formations Récrée Tech, des fondations Claude au design produit.</p>

                <ul class="cat-hero-stats">
                    <li><strong>{{ totalFormations }}</strong><span>formation{{ totalFormations > 1 ? 's' : '' }}</span></li>
                    <li><strong>{{ totalModules }}</strong><span>modules</span></li>
                    <li><strong>{{ totalLessons }}</strong><span>leçons</span></li>
                    {% if enrolledCount > 0 %}
                        <li class="is-mine"><strong>{{ enrolledCount }}</strong><span>{{ enrolledCount > 1 ? 'à toi' : 'à toi' }}</span></li>
                    {% endif %}
                </ul>
            </div>
        </section>

        <section class="cat-grid-section">
            <div class="cat-section-head">
                <h2 class="cat-section-title">— Les <em>formations</em></h2>
                <span class="cat-section-hint">★ Triées par ordre de sortie</span>
            </div>

            <div class="cat-grid">
                {% for card in cards %}
                    {% set f = card.formation %}
                    <article class="cat-card {{ card.enrolled ? 'is-enrolled' : '' }} {{ card.vipGranted ? 'is-vip' : '' }}">

                        <a href="{{ path('app_formation_show', { slug: f.slug }) }}" class="cat-card-cover-link" aria-label="Voir {{ f.title }}">
                            <div class="cat-card-cover">
                                <div class="cat-card-cover-fallback">
                                    <span class="cat-card-cover-grid" aria-hidden="true"></span>
                                    <span class="cat-card-cover-eyebrow">★ La Récré Tech · Formation</span>
                                    <span class="cat-card-cover-num">{{ '%02d'|format(loop.index) }}</span>
                                    <span class="cat-card-cover-title">{{ f.title }}</span>
                                    {% if f.subtitle %}<span class="cat-card-cover-sub">{{ f.subtitle }}</span>{% endif %}
                                </div>
                                <div class="cat-card-cover-overlay" aria-hidden="true"></div>
                                {% if card.enrolled %}
                                    <span class="cat-card-badge {{ card.vipGranted ? 'is-vip' : '' }}">{{ card.vipGranted ? '★ VIP' : '✓ Inscrit·e' }}</span>
                                {% endif %}
                            </div>
                        </a>

                        <div class="cat-card-body">
                            <span class="cat-card-eyebrow">— Formation · {{ card.modulesCount }} modules · {{ card.totalDurationFormatted }}</span>
                            <h3 class="cat-card-title">
                                <a href="{{ path('app_formation_show', { slug: f.slug }) }}">{{ f.title }}</a>
                            </h3>
                            {% if f.subtitle %}<p class="cat-card-sub">{{ f.subtitle }}</p>{% endif %}

                            {% if card.enrolled %}
                                <div class="cat-card-progress">
                                    <progress class="cat-card-progress-bar" max="100" value="{{ card.progressPercent }}" aria-label="Progression formation {{ f.title }}">{{ card.progressPercent }} %</progress>
                                    <div class="cat-card-progress-meta">
                                        <span><strong>{{ card.progressPercent }} %</strong> de la formation</span>
                                        <span>{{ card.completedLessonsCount }} / {{ card.lessonsCount }} leçons</span>
                                    </div>
                                </div>
                            {% else %}
                                <div class="cat-card-price-row">
                                    <span class="cat-card-price-label">Tarif</span>
                                    <span class="cat-card-price">{{ f.priceFormatted }}</span>
                                </div>
                            {% endif %}

                            <a href="{{ path('app_formation_show', { slug: f.slug }) }}" class="cat-card-cta {{ card.enrolled ? 'is-resume' : '' }}">
                                {{ card.enrolled ? '▶ Reprendre la formation' : 'Découvrir le programme →' }}
                            </a>
                        </div>
                    </article>
                {% else %}
                    <p>Aucune formation publiée pour le moment.</p>
                {% endfor %}
            </div>
        </section>

    </main>

    <footer class="app-footer">
        © 2026 La Récrée Tech · app.larecreetech.com
    </footer>

</div>
{% endblock %}
